# Whoop OAuth client credentials (from https://developer-dashboard.whoop.com/apps)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# whoop-auth (local, one-time OAuth+PKCE bootstrap): must be a localhost
# callback, registered on the Whoop app's Redirect URLs.
# WHOOP_REDIRECT_URI=http://localhost:8080/oauth/callback

# Override the local token file location (stdio mode and whoop-auth).
# WHOOP_TOKEN_FILE=/absolute/path/to/token.json

# HTTP mode (single-tenant, e.g. Docker/Railway): set PORT (or MCP_HTTP_ADDR)
# to enable it, plus a bearer secret clients must send as
# `Authorization: Bearer <MCP_AUTH_TOKEN>`. WHOOP_REFRESH_TOKEN seeds the
# token store on first boot only — get it by running whoop-auth locally
# first and reading refresh_token out of the saved token file.
# PORT=8080
# MCP_AUTH_TOKEN=
# WHOOP_REFRESH_TOKEN=
