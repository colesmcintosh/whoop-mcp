# Whoop OAuth client credentials (from https://developer-dashboard.whoop.com/apps)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# stdio mode (personal): use a localhost callback. Must be registered on
# the Whoop app's Redirect URLs.
# WHOOP_REDIRECT_URI=http://localhost:8080/oauth/callback

# HTTP mode (hosted multi-tenant): set these instead.
# PUBLIC_URL is the externally-reachable HTTPS URL of this server (no
# trailing slash). WHOOP_REDIRECT_URI must equal $PUBLIC_URL/oauth/callback
# and must be registered on the Whoop app.
# PUBLIC_URL=https://example.com
# WHOOP_REDIRECT_URI=https://example.com/oauth/callback
# PORT=8080
# USER_STORE_DIR=/data/users

# stdio mode only: override the local token file location.
# WHOOP_TOKEN_FILE=/absolute/path/to/token.json
