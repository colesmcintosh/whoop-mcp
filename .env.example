# Whoop OAuth client credentials (from https://developer-dashboard.whoop.com/apps)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Listen address. Defaults to :8080. Platforms like Railway set PORT.
# PORT=8080
# MCP_HTTP_ADDR=:8080

# Externally-reachable HTTPS URL of this server (no trailing slash). Used to
# build the OAuth redirect URI and the MCP URL shown in the UI. Leave unset for
# purely-local use; it's derived from the request.
# PUBLIC_URL=https://example.com

# Override the OAuth callback URL. Defaults to $PUBLIC_URL/oauth/callback, or a
# localhost callback. Must be registered on the Whoop app's Redirect URLs.
# WHOOP_REDIRECT_URI=https://example.com/oauth/callback

# Shared secret. When set, gates the browser UI and requires
# `Authorization: Bearer <AUTH_TOKEN>` on the /mcp endpoint. Set this whenever
# the server is reachable over a network. Generate with: openssl rand -hex 32
# AUTH_TOKEN=

# Where the single Whoop token is stored. `file` (default) writes JSON to
# WHOOP_TOKEN_FILE; `keyring` uses the OS keychain.
# WHOOP_TOKEN_BACKEND=file
# WHOOP_TOKEN_FILE=/absolute/path/to/token.json
